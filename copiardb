LC_ALL=C
SECONDS=0
IFS=" "
LOCKFILE="/tmp/$(basename $0)_$(whoami)"
LOCKFD="150"
nom=$(basename "$0")
archi="/app/resultado.txt"

function clean_1() {
	rm -f /run/$(basename $0).pid
        rm -f "$LOCKFILE"
	rm -f $archi
}

function ayuda() {
	echo "Ejemplo: $nom IP1 PORT1 IP2 PORT2 NOMBREDB USER1 PASSWORD1 USER2 PASSWORD2"
	exit 1
}

function lock() {
        echo {LOCKFD}>$LOCKFILE
        flock -n $LOCKFD
}

function exit_error() {
        echo "ERROR: Ya hay una instancia en ejecución. Saliendo"
        exit 1
}

echo "$BASHPID" > /run/$(basename $0).pid
trap "clean_1; exit" 0 1 2 3 15
lock || exit_error

if [[ $(dpkg --get-selections | grep -w "postgresql-client" | awk '{print $1}' | head -1) = postgresql-client ]]; then
	echo "" > /dev/null
else
	echo "ERROR: el paquete postgresql-client no esta instalado."
	exit 1
fi

